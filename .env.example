# VNPay Configuration
# Copy file này thành .env và điền các giá trị thực tế

VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=/vnpay-payment
VNPAY_TMN_CODE=YOUR_TMN_CODE_HERE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET_HERE
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction

# Để sử dụng:
# 1. Copy file này: cp .env.example .env
# 2. Thay thế YOUR_TMN_CODE_HERE và YOUR_HASH_SECRET_HERE bằng giá trị thực tế từ VNPay
# 3. Đối với production, thay đổi URL từ sandbox sang production
